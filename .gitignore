# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies - install from lock files instead of committing packages
node_modules/
server/node_modules/

# Build outputs - generated by npm run build
dist/
dist-ssr/
coverage/

# Environment files (SENSITIVE - DO NOT COMMIT!)
*.local
.env
.env.*
!.env.example

# Local databases and runtime state (SENSITIVE!)
server/database.sqlite
server/data/*
!server/data/.gitkeep

# Upload files / generated media (user generated content)
server/uploads/*
!server/uploads/.gitkeep

# Server runtime logs and debug output
server/*.log
server/queue.log
server/server.log
server/debug*.txt

# Local deployment files / backups / archives
archive/
*.tar.gz
*.tgz
*.zip
*.bak
nginx*.conf
nginx_*.conf
*.conf.new

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temp/cache files
*.tmp
*.temp
.cache/
.snow/
