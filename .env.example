# NewBie Anime Generator 环境变量模板
# 复制为 .env.local 或 .env.server 后填写真实值。
# .env.local / .env.server 不会被提交到 Git。

# Frontend / ComfyUI
VITE_COMFY_URL=http://localhost:8188
VITE_COMFY_URL_STANDARD=http://localhost:8189
VITE_CF_ACCESS_CLIENT_ID=
VITE_CF_ACCESS_CLIENT_SECRET=

# Server
PORT=3001
NODE_ENV=development
SESSION_SECRET=change-me-in-production

# AI service API keys - 请勿在此模板中填写真实密钥
GEMINI_API_KEY=
API_KEY=
SILICONFLOW_API_KEY=
NOVELAI_API_KEY=

# Optional Cloudflare Access headers for server-side requests
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=