server {
    listen 80;
    server_name newbie.rimeleaf.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name newbie.rimeleaf.com;

    ssl_certificate /etc/letsencrypt/live/newbie.rimeleaf.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/newbie.rimeleaf.com/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # 前端静态文件
    root /home/frostleaf/CascadeProjects/newbie/dist;
    index index.html;

    # 代理 AI 助手 API
    location /api {
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # 代理 ComfyUI API (必须在 / 之前)
    location /comfyui {
        rewrite ^/comfyui/(.*) /$1 break;
        rewrite ^/comfyui$ / break;
        proxy_pass http://e608ebf6659745cba177ca2aef23e50b.cloud.lanyun.net:18188;
        proxy_set_header Host e608ebf6659745cba177ca2aef23e50b.cloud.lanyun.net;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
